            RowBox[{"\[Lambda]1", ",", "v1"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"\[Lambda]2", ",", "v2"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"\[Lambda]3", ",", "v3"}], "}"}]}], "}"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"resp", "=", 
         RowBox[{"SortBy", "[", 
          RowBox[{"res", ",", 
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"#", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "]"}], "&"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"eigval", "=", 
         RowBox[{"resp", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"U", "=", 
         RowBox[{"Transpose", "[", 
          RowBox[{"resp", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"U", "=", 
           RowBox[{
            RowBox[{"Transpose", "[", "resp", "]"}], "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], ";"}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"U", "=", 
           RowBox[{"Transpose", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"res", "[", 
               RowBox[{"[", 
                RowBox[{"2", ",", 
                 RowBox[{
                  RowBox[{"Position", "[", 
                   RowBox[{
                    RowBox[{"res", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], ",", 
                    RowBox[{"Min", "[", 
                    RowBox[{"res", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "]"}], "[", 
                  RowBox[{"[", 
                   RowBox[{"1", ",", "1"}], "]"}], "]"}]}], "]"}], "]"}], ",", 
              RowBox[{"res", "[", 
               RowBox[{"[", 
                RowBox[{"2", ",", 
                 RowBox[{
                  RowBox[{"Select", "[", 
                   RowBox[{
                    RowBox[{"{", 
                    RowBox[{"1", ",", "2", ",", "3"}], "}"}], ",", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"#", "\[NotEqual]", 
                    RowBox[{
                    RowBox[{"Position", "[", 
                    RowBox[{
                    RowBox[{"res", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], ",", 
                    RowBox[{"Min", "[", 
