     RowBox[{
      RowBox[{"mat", "//", "CForm"}], "//", "ToString"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\"\<List(List(\>\"", "\[Rule]", "\"\<{{\>\""}], ",", 
       RowBox[{"\"\<),List(\>\"", "\[Rule]", "\"\<},{\>\""}], ",", 
       RowBox[{
        RowBox[{"RegularExpression", "[", "\"\<\\\\)\\\\)$\>\"", "]"}], 
        "\[Rule]", "\"\<}}\>\""}], ",", 
       RowBox[{
        RowBox[{
        "RegularExpression", "[", "\"\<Sqrt\\\\((\\\\d+)\\\\)\>\"", "]"}], 
        "\[Rule]", "\"\<sqrt($1.L)\>\""}], ",", 
       RowBox[{
        RowBox[{
        "RegularExpression", "[", "\"\<Power\\\\((\\\\w+),(\\\\d+)\\\\)\>\"", 
         "]"}], "\[Rule]", "\"\<pow($1,$2.L)\>\""}], ",", 
       RowBox[{"\"\<Power(E,\>\"", "\[Rule]", "\"\<exp(\>\""}], ",", 
       RowBox[{
        RowBox[{"RegularExpression", "[", "\"\<(\\\\d+)\\\\*\>\"", "]"}], 
        "\[Rule]", "\"\<$1.L*\>\""}], ",", 
       RowBox[{
        RowBox[{"RegularExpression", "[", "\"\<(\\\\d+) \\\\+\>\"", "]"}], 
        "\[Rule]", "\"\<$1.L +\>\""}], ",", 
       RowBox[{
        RowBox[{"RegularExpression", "[", "\"\<(\\\\d+) -\>\"", "]"}], 
        "\[Rule]", "\"\<$1.L -\>\""}]}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"makeCform", "[", "mat_", "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", "str", "}"}], ",", 
    RowBox[{
     RowBox[{"str", "=", 
      RowBox[{"makeCform0", "[", "mat", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"StringReplace", "[", 
      RowBox[{"str", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"RegularExpression", "[", "\"\<Y(\\\\d+)\\\\.L\>\"", "]"}], 
         "\[Rule]", "\"\<Y$1\>\""}], "}"}]}], "]"}]}]}], "]"}]}]}], "Input",
