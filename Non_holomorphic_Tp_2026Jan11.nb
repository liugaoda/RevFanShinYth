        "\[Rule]", "\"\<}}\>\""}], ",", 
       RowBox[{
        RowBox[{
        "RegularExpression", "[", "\"\<Sqrt\\\\((\\\\d+)\\\\)\>\"", "]"}], 
        "\[Rule]", "\"\<sqrt($1.L)\>\""}], ",", 
       RowBox[{
