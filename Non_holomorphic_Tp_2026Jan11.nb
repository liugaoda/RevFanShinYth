Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"LeptonWeinbergNO3m", "[", 
    RowBox[{"Ml_", ",", "M\[Nu]_", ",", "bestinput_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "Mvsq", ",", "Mlsq", ",", "resMv", ",", "resMl", ",", "meSq", ",", 
       "m\[Mu]Sq", ",", "m\[Tau]Sq", ",", "m1Sq", ",", "m2Sq", ",", "m3Sq", 
       ",", "\[CapitalDelta]21", ",", "\[CapitalDelta]31", ",", "Ul", ",", 
       "Uv", ",", "phase", ",", "Uvp", ",", "UPMNS", ",", "sinSq\[Theta]13", 
       ",", "sin\[Theta]13", ",", "cos\[Theta]13", ",", "sinSq\[Theta]12", 
       ",", "sin\[Theta]12", ",", "cos\[Theta]12", ",", "sinSq\[Theta]23", 
       ",", "sin\[Theta]23", ",", "cos\[Theta]23", ",", "\[Delta]CP", ",", 
       "\[Alpha]21CP", ",", "\[Alpha]31CPp", ",", "\[Alpha]31CP", ",", 
       "memuratio", ",", "mmutauratio", ",", "Delta2131ratio", ",", "obs", 
       ",", "mean", ",", " ", "errup", ",", "errdown", ",", "chisq", ",", 
       "\[Lambda]", ",", "\[Lambda]e", ",", "i", ",", "z", ",", "m1", ",", 
       "m2", ",", "m3", ",", "msum", ",", "me", ",", "mce", ",", "mc\[Mu]", 
       ",", "mc\[Tau]"}], "}"}], ",", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Mvsq", "=", 
       RowBox[{"SetPrecision", "[", 
        RowBox[{
         RowBox[{"FullSimplify", "[", 
          RowBox[{
           RowBox[{"ConjugateTranspose", "[", "M\[Nu]", "]"}], ".", 
           "M\[Nu]"}], "]"}], ",", "30"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Mlsq", "=", 
       RowBox[{"SetPrecision", "[", 
        RowBox[{
         RowBox[{"FullSimplify", "[", 
          RowBox[{
           RowBox[{"ConjugateTranspose", "[", "Ml", "]"}], ".", "Ml"}], "]"}],
          ",", "30"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"resMv", "=", 
       RowBox[{"DiagNO", "[", "Mvsq", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"resMl", "=", 
       RowBox[{"DiagNO", "[", "Mlsq", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"meSq", "=", 
       RowBox[{"resMl", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"m\[Mu]Sq", "=", 
       RowBox[{"resMl", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "2"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"m\[Tau]Sq", "=", 
       RowBox[{"resMl", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "3"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"m1Sq", "=", 
       RowBox[{"resMv", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"m2Sq", "=", 
       RowBox[{"resMv", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "2"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"m3Sq", "=", 
       RowBox[{"resMv", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "3"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"\[CapitalDelta]21", "=", 
       RowBox[{"m2Sq", "-", "m1Sq"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"\[CapitalDelta]31", "=", 
       RowBox[{"m3Sq", "-", "m1Sq"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Ul", "=", 
       RowBox[{"resMl", "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Uv", "=", 
       RowBox[{"resMv", "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"phase", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"Transpose", "[", "Uv", "]"}], ".", "M\[Nu]", ".", "Uv"}], "//",
         "FullSimplify"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Uvp", "=", 
       RowBox[{"Uv", ".", 
        RowBox[{"DiagonalMatrix", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "I"}], "*", 
             RowBox[{
              RowBox[{"Arg", "[", 
               RowBox[{"phase", "[", 
                RowBox[{"[", 
                 RowBox[{"1", ",", "1"}], "]"}], "]"}], "]"}], "/", "2"}]}], 
            "]"}], ",", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "I"}], "*", 
             RowBox[{
              RowBox[{"Arg", "[", 
               RowBox[{"phase", "[", 
                RowBox[{"[", 
                 RowBox[{"2", ",", "2"}], "]"}], "]"}], "]"}], "/", "2"}]}], 
            "]"}], ",", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "I"}], "*", 
             RowBox[{
              RowBox[{"Arg", "[", 
               RowBox[{"phase", "[", 
                RowBox[{"[", 
                 RowBox[{"3", ",", "3"}], "]"}], "]"}], "]"}], "/", "2"}]}], 
            "]"}]}], "}"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"UPMNS", "=", 
       RowBox[{
        RowBox[{"ConjugateTranspose", "[", "Ul", "]"}], ".", "Uvp"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"sinSq\[Theta]13", "=", 
       RowBox[{
        RowBox[{"abs", "[", 
         RowBox[{"UPMNS", "[", 
          RowBox[{"[", 
           RowBox[{"1", ",", "3"}], "]"}], "]"}], "]"}], "^", "2"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"sin\[Theta]13", "=", 
       RowBox[{"Sqrt", "[", "sinSq\[Theta]13", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"cos\[Theta]13", "=", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"1", "-", "sinSq\[Theta]13"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"sinSq\[Theta]12", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"abs", "[", 
          RowBox[{"UPMNS", "[", 
           RowBox[{"[", 
            RowBox[{"1", ",", "2"}], "]"}], "]"}], "]"}], "^", "2"}], "/", 
        RowBox[{"(", 
         RowBox[{"1", "-", "sinSq\[Theta]13"}], ")"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"sin\[Theta]12", "=", 
       RowBox[{"Sqrt", "[", "sinSq\[Theta]12", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"cos\[Theta]12", "=", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"1", "-", "sinSq\[Theta]12"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"sinSq\[Theta]23", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"abs", "[", 
          RowBox[{"UPMNS", "[", 
           RowBox[{"[", 
            RowBox[{"2", ",", "3"}], "]"}], "]"}], "]"}], "^", "2"}], "/", 
        RowBox[{"(", 
         RowBox[{"1", "-", "sinSq\[Theta]13"}], ")"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"sin\[Theta]23", "=", 
       RowBox[{"Sqrt", "[", "sinSq\[Theta]23", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"cos\[Theta]23", "=", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"1", "-", "sinSq\[Theta]23"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"\[Delta]CP", "=", 
       RowBox[{"Arg", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"UPMNS", "[", 
               RowBox[{"[", 
                RowBox[{"1", ",", "1"}], "]"}], "]"}], "*", 
              RowBox[{"UPMNS", "[", 
               RowBox[{"[", 
                RowBox[{"3", ",", "3"}], "]"}], "]"}], "*", 
              RowBox[{"Conjugate", "[", 
               RowBox[{"UPMNS", "[", 
                RowBox[{"[", 
                 RowBox[{"1", ",", "3"}], "]"}], "]"}], "]"}], "*", 
              RowBox[{"Conjugate", "[", 
               RowBox[{"UPMNS", "[", 
                RowBox[{"[", 
                 RowBox[{"3", ",", "1"}], "]"}], "]"}], "]"}]}], ")"}], "/", 
