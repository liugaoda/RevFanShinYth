Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"TpInvarContra", "[", "rep_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"fieldnumb", ",", "res", ",", "resp"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"fieldnumb", "=", 
       RowBox[{"Length", "[", "rep", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"res", "=", 
       RowBox[{"Which", "[", 
        RowBox[{
         RowBox[{"fieldnumb", "\[Equal]", "2"}], ",", 
         RowBox[{"TpContract", "[", 
          RowBox[{
           RowBox[{"rep", "[", 
            RowBox[{"[", "1", "]"}], "]"}], ",", 
           RowBox[{"rep", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], "]"}], ",", 
         RowBox[{"fieldnumb", "\[Equal]", "3"}], ",", 
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{"Map", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"TpContract", "[", 
               RowBox[{
                RowBox[{"rep", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], ",", "#"}], "]"}], "&"}], 
             ",", 
             RowBox[{"TpContract", "[", 
              RowBox[{
               RowBox[{"rep", "[", 
                RowBox[{"[", "2", "]"}], "]"}], ",", 
               RowBox[{"rep", "[", 
                RowBox[{"[", "3", "]"}], "]"}]}], "]"}]}], "]"}], ",", "1"}], 
          "]"}], ",", 
         RowBox[{"fieldnumb", "\[Equal]", "4"}], ",", 
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{"Map", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"TpContract", "[", 
               RowBox[{
                RowBox[{"rep", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], ",", "#"}], "]"}], "&"}], 
             ",", 
