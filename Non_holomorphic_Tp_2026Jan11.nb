        "\[Rule]", "\"\<$1.L*\>\""}], ",", 
       RowBox[{
        RowBox[{"RegularExpression", "[", "\"\<(\\\\d+) \\\\+\>\"", "]"}], 
        "\[Rule]", "\"\<$1.L +\>\""}], ",", 
       RowBox[{
        RowBox[{"RegularExpression", "[", "\"\<(\\\\d+) -\>\"", "]"}], 
        "\[Rule]", "\"\<$1.L -\>\""}]}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
