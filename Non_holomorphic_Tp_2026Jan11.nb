     RowBox[{"{", 
      RowBox[{
       RowBox[{"\"\<List(List(\>\"", "\[Rule]", "\"\<{{\>\""}], ",", 
       RowBox[{"\"\<),List(\>\"", "\[Rule]", "\"\<},{\>\""}], ",", 
       RowBox[{
