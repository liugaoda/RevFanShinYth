Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"DiagNO", "[", "H_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "h1", ",", "h2", ",", "h3", ",", "h4", ",", "h5", ",", "h6", ",", "a",
          ",", "b", ",", "c", ",", "d", ",", "\[Alpha]", ",", "\[Beta]", ",", 
         "S", ",", "\[Lambda]1", ",", "\[Lambda]2", ",", "\[Lambda]3", ",", 
         "C1", ",", "C2", ",", "C3", ",", "v1", ",", "v2", ",", "v3", ",", 
         "U", ",", "diagH", ",", "\[CapitalDelta]", ",", "Udag", ",", 
         "Sin13sq", ",", "Sin12sq", ",", "Sin23sq", ",", "theta13", ",", 
         "theta12", ",", "theta23", ",", "\[Delta]", ",", "res", ",", "resp", 
         ",", "eigval"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"h1", "=", 
         RowBox[{"H", "[", 
          RowBox[{"[", 
           RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"h2", "=", 
         RowBox[{"H", "[", 
          RowBox[{"[", 
           RowBox[{"1", ",", "2"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"h3", "=", 
         RowBox[{"H", "[", 
          RowBox[{"[", 
           RowBox[{"1", ",", "3"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"h4", "=", 
         RowBox[{"H", "[", 
          RowBox[{"[", 
           RowBox[{"2", ",", "2"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"h5", "=", 
         RowBox[{"H", "[", 
          RowBox[{"[", 
           RowBox[{"2", ",", "3"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"h6", "=", 
         RowBox[{"H", "[", 
          RowBox[{"[", 
           RowBox[{"3", ",", "3"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"a", "=", "1"}], ";", "\[IndentingNewLine]", 
        RowBox[{"b", "=", 
         RowBox[{"-", 
          RowBox[{"(", 
           RowBox[{"h1", "+", "h4", "+", "h6"}], ")"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"c", "=", 
         RowBox[{
          RowBox[{"h1", "*", "h4"}], "+", 
          RowBox[{"h1", "*", "h6"}], "+", 
          RowBox[{"h4", "*", "h6"}], "-", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"h2", "*", 
             RowBox[{"Conjugate", "[", "h2", "]"}]}], "+", 
            RowBox[{"h3", "*", 
             RowBox[{"Conjugate", "[", "h3", "]"}]}], "+", 
            RowBox[{"h5", "*", 
             RowBox[{"Conjugate", "[", "h5", "]"}]}]}], ")"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"d", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "h1"}], "*", "h4", "*", "h6"}], "+", 
          RowBox[{"h2", "*", 
           RowBox[{"Conjugate", "[", "h2", "]"}], "*", "h6"}], "+", 
          RowBox[{"h3", "*", 
           RowBox[{"Conjugate", "[", "h3", "]"}], "*", "h4"}], "-", 
          RowBox[{"h2", "*", 
           RowBox[{"Conjugate", "[", "h3", "]"}], "*", "h5"}], "+", 
          RowBox[{"h1", "*", "h5", "*", 
           RowBox[{"Conjugate", "[", "h5", "]"}]}], "-", 
          RowBox[{
           RowBox[{"Conjugate", "[", "h2", "]"}], "*", "h3", "*", 
           RowBox[{"Conjugate", "[", "h5", "]"}]}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"\[Alpha]", "=", 
         RowBox[{"(", 
          RowBox[{
           FractionBox[
            RowBox[{"-", 
             SuperscriptBox["b", "3"]}], 
            RowBox[{"27", "*", 
             SuperscriptBox["a", "3"]}]], "+", 
           FractionBox[
            RowBox[{"-", "d"}], 
            RowBox[{"2", "*", "a"}]], "+", 
           FractionBox[
            RowBox[{"b", "*", "c"}], 
            RowBox[{"6", "*", 
             SuperscriptBox["a", "2"]}]]}], ")"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"\[Beta]", "=", 
         RowBox[{"(", 
          RowBox[{
           FractionBox["c", 
            RowBox[{"3", "*", "a"}]], "-", 
           FractionBox[
            SuperscriptBox["b", "2"], 
            RowBox[{"9", "*", 
             SuperscriptBox["a", "2"]}]]}], ")"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"\[CapitalDelta]", "=", 
         RowBox[{
          RowBox[{
           SuperscriptBox["\[Alpha]", "2"], "+", 
           SuperscriptBox["\[Beta]", "3"]}], "//", "N"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"S", "=", 
         RowBox[{"Cos", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "/", "3"}], ")"}], "*", 
           RowBox[{"ArcCos", "[", 
            FractionBox["\[Alpha]", 
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{"-", "\[Beta]"}], ")"}], 
              RowBox[{"3", "/", "2"}]]], "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"\[Lambda]3", "=", 
         RowBox[{
          RowBox[{
           FractionBox[
            RowBox[{"-", "b"}], 
            RowBox[{"3", "*", "a"}]], "+", 
           RowBox[{"2", "*", 
            RowBox[{"Sqrt", "[", 
             RowBox[{"-", "\[Beta]"}], "]"}], "*", "S"}]}], "//", "N"}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"\[Lambda]1", "=", 
         RowBox[{
          RowBox[{
           FractionBox[
            RowBox[{"-", "b"}], 
            RowBox[{"3", "*", "a"}]], "-", 
           RowBox[{
            RowBox[{"Sqrt", "[", 
             RowBox[{"-", "\[Beta]"}], "]"}], "*", 
            RowBox[{"(", 
             RowBox[{"S", "+", 
              RowBox[{
               RowBox[{"Sqrt", "[", "3", "]"}], "*", 
               RowBox[{"Sqrt", "[", 
                RowBox[{"1", "-", 
                 SuperscriptBox["S", "2"]}], "]"}]}]}], ")"}]}]}], "//", 
          "N"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"\[Lambda]2", "=", 
         RowBox[{
          RowBox[{
           FractionBox[
            RowBox[{"-", "b"}], 
            RowBox[{"3", "*", "a"}]], "-", 
           RowBox[{
            RowBox[{"Sqrt", "[", 
             RowBox[{"-", "\[Beta]"}], "]"}], "*", 
            RowBox[{"(", 
             RowBox[{"S", "-", 
              RowBox[{
               RowBox[{"Sqrt", "[", "3", "]"}], "*", 
               RowBox[{"Sqrt", "[", 
                RowBox[{"1", "-", 
                 SuperscriptBox["S", "2"]}], "]"}]}]}], ")"}]}]}], "//", 
          "N"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"C1", "=", 
         RowBox[{
          RowBox[{"Sqrt", "[", 
           RowBox[{
            SuperscriptBox[
             RowBox[{"Abs", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"\[Lambda]1", "-", "h6"}], ")"}], "*", 
                RowBox[{"Conjugate", "[", "h2", "]"}]}], "+", 
               RowBox[{"h5", "*", 
                RowBox[{"Conjugate", "[", "h3", "]"}]}]}], "]"}], "2"], "+", 
            SuperscriptBox[
             RowBox[{"Abs", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"\[Lambda]1", "-", "h4"}], ")"}], "*", 
                RowBox[{"Conjugate", "[", "h3", "]"}]}], "+", 
               RowBox[{
                RowBox[{"Conjugate", "[", "h2", "]"}], "*", 
                RowBox[{"Conjugate", "[", "h5", "]"}]}]}], "]"}], "2"], "+", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"\[Lambda]1", "-", "h4"}], ")"}], "*", 
                RowBox[{"(", 
                 RowBox[{"\[Lambda]1", "-", "h6"}], ")"}]}], "-", 
               SuperscriptBox[
                RowBox[{"Abs", "[", "h5", "]"}], "2"]}], ")"}], "2"]}], "]"}],
           "//", "N"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"C2", "=", 
         RowBox[{
          RowBox[{"Sqrt", "[", 
           RowBox[{
            SuperscriptBox[
             RowBox[{"Abs", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"\[Lambda]2", "-", "h6"}], ")"}], "*", "h2"}], "+", 
               RowBox[{"h3", "*", 
                RowBox[{"Conjugate", "[", "h5", "]"}]}]}], "]"}], "2"], "+", 
            SuperscriptBox[
             RowBox[{"Abs", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"\[Lambda]2", "-", "h1"}], ")"}], "*", 
                RowBox[{"Conjugate", "[", "h5", "]"}]}], "+", 
               RowBox[{"h2", "*", 
                RowBox[{"Conjugate", "[", "h3", "]"}]}]}], "]"}], "2"], "+", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"\[Lambda]2", "-", "h1"}], ")"}], "*", 
                RowBox[{"(", 
                 RowBox[{"\[Lambda]2", "-", "h6"}], ")"}]}], "-", 
               SuperscriptBox[
                RowBox[{"Abs", "[", "h3", "]"}], "2"]}], ")"}], "2"]}], "]"}],
           "//", "N"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"C3", "=", 
         RowBox[{
          RowBox[{"Sqrt", "[", 
           RowBox[{
            SuperscriptBox[
             RowBox[{"Abs", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"\[Lambda]3", "-", "h4"}], ")"}], "*", "h3"}], "+", 
               RowBox[{"h2", "*", "h5"}]}], "]"}], "2"], "+", 
            SuperscriptBox[
             RowBox[{"Abs", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"\[Lambda]3", "-", "h1"}], ")"}], "*", "h5"}], "+", 
               RowBox[{"h3", "*", 
                RowBox[{"Conjugate", "[", "h2", "]"}]}]}], "]"}], "2"], "+", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"\[Lambda]3", "-", "h1"}], ")"}], "*", 
                RowBox[{"(", 
                 RowBox[{"\[Lambda]3", "-", "h4"}], ")"}]}], "-", 
               SuperscriptBox[
                RowBox[{"Abs", "[", "h2", "]"}], "2"]}], ")"}], "2"]}], "]"}],
           "//", "N"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"v1", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "/", "C1"}], ")"}], "*", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"\[Lambda]1", "-", "h4"}], ")"}], "*", 
               RowBox[{"(", 
                RowBox[{"\[Lambda]1", "-", "h6"}], ")"}]}], "-", 
              SuperscriptBox[
               RowBox[{"Abs", "[", "h5", "]"}], "2"]}], ",", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"\[Lambda]1", "-", "h6"}], ")"}], "*", 
               RowBox[{"Conjugate", "[", "h2", "]"}]}], "+", 
              RowBox[{"h5", "*", 
               RowBox[{"Conjugate", "[", "h3", "]"}]}]}], ",", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"\[Lambda]1", "-", "h4"}], ")"}], "*", 
               RowBox[{"Conjugate", "[", "h3", "]"}]}], "+", 
              RowBox[{
               RowBox[{"Conjugate", "[", "h2", "]"}], "*", 
               RowBox[{"Conjugate", "[", "h5", "]"}]}]}]}], "}"}]}], "//", 
          "N"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"v2", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "/", "C2"}], ")"}], "*", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"\[Lambda]2", "-", "h6"}], ")"}], "*", "h2"}], "+", 
              RowBox[{"h3", "*", 
               RowBox[{"Conjugate", "[", "h5", "]"}]}]}], ",", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"\[Lambda]2", "-", "h1"}], ")"}], "*", 
               RowBox[{"(", 
                RowBox[{"\[Lambda]2", "-", "h6"}], ")"}]}], "-", 
              SuperscriptBox[
               RowBox[{"Abs", "[", "h3", "]"}], "2"]}], ",", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"\[Lambda]2", "-", "h1"}], ")"}], "*", 
               RowBox[{"Conjugate", "[", "h5", "]"}]}], "+", 
              RowBox[{"h2", "*", 
               RowBox[{"Conjugate", "[", "h3", "]"}]}]}]}], "}"}]}], "//", 
          "N"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"v3", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "/", "C3"}], ")"}], "*", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"\[Lambda]3", "-", "h4"}], ")"}], "*", "h3"}], "+", 
              RowBox[{"h2", "*", "h5"}]}], ",", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"\[Lambda]3", "-", "h1"}], ")"}], "*", "h5"}], "+", 
              RowBox[{"h3", "*", 
               RowBox[{"Conjugate", "[", "h2", "]"}]}]}], ",", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"\[Lambda]3", "-", "h1"}], ")"}], "*", 
               RowBox[{"(", 
                RowBox[{"\[Lambda]3", "-", "h4"}], ")"}]}], "-", 
              SuperscriptBox[
               RowBox[{"Abs", "[", "h2", "]"}], "2"]}]}], "}"}]}], "//", 
          "N"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"res", "=", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"\[Lambda]1", ",", "\[Lambda]2", ",", "\[Lambda]3"}], 
              "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"v1", ",", "v2", ",", "v3"}], "}"}]}], "}"}]}], ";"}], 
