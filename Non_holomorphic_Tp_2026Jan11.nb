                    RowBox[{"rep", "[", 
                    RowBox[{"[", "2", "]"}], "]"}], ",", "#"}], "]"}], "&"}], 
                 ",", 
                 RowBox[{"TpContract", "[", 
                  RowBox[{
                   RowBox[{"rep", "[", 
                    RowBox[{"[", "3", "]"}], "]"}], ",", 
                   RowBox[{"rep", "[", 
                    RowBox[{"[", "4", "]"}], "]"}]}], "]"}]}], "]"}], ",", 
               "1"}], "]"}]}], "]"}], ",", "1"}], "]"}], ",", 
         RowBox[{"fieldnumb", "\[Equal]", "5"}], ",", 
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{"Map", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"TpContract", "[", 
               RowBox[{
                RowBox[{"rep", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], ",", "#"}], "]"}], "&"}], 
             ",", 
             RowBox[{"Flatten", "[", 
              RowBox[{
               RowBox[{"Map", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"TpContract", "[", 
                   RowBox[{
                    RowBox[{"rep", "[", 
                    RowBox[{"[", "2", "]"}], "]"}], ",", "#"}], "]"}], "&"}], 
                 ",", 
                 RowBox[{"Flatten", "[", 
                  RowBox[{
                   RowBox[{"Map", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"TpContract", "[", 
                    RowBox[{
                    RowBox[{"rep", "[", 
                    RowBox[{"[", "3", "]"}], "]"}], ",", "#"}], "]"}], "&"}], 
                    ",", 
                    RowBox[{"TpContract", "[", 
                    RowBox[{
                    RowBox[{"rep", "[", 
                    RowBox[{"[", "4", "]"}], "]"}], ",", 
                    RowBox[{"rep", "[", 
                    RowBox[{"[", "5", "]"}], "]"}]}], "]"}]}], "]"}], ",", 
                   "1"}], "]"}]}], "]"}], ",", "1"}], "]"}]}], "]"}], ",", 
           "1"}], "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"resp", "=", 
       RowBox[{"Select", "[", 
        RowBox[{"res", ",", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "4", "]"}], "]"}], "===", 
           "\"\<\!\(\*SubscriptBox[\(1\), \(0\)]\)\>\""}], "&"}]}], "]"}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"FullSimplify", "[", 
       RowBox[{"resp", "[", 
        RowBox[{"[", 
